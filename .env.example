# Optional compose profile selector (used with docker compose --env-file)
# ORG_CHEM_ENV_FILE=../.env

# Postgres
PGHOST=db
PGPORT=5432
PGDATABASE=orgchem
PGUSER=orgchem_app
PGPASSWORD=change-me
# App
LOG_LEVEL=INFO

# Host path to CSV directory used by ingest container
ORG_CHEM_HOST_DATA_DIR=/absolute/path/to/data_insert_trial
